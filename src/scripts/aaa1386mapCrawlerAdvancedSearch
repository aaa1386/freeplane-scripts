        sourceGroup = new ButtonGroup()
        sourceGroup.add(folderRadio)
        sourceGroup.add(openMapsRadio)
        sourceGroup.add(selectedDescRadio)
        sourceGroup.add(selectedSibRadio)
        sourceGroup.add(rootRadio)   // اضافه به گروه
        
        folderChooserBtn = new JButton("📁 Choose Folder")
        folderChooserBtn.addActionListener({ selectFolder() })
        folderLabel = new JLabel(shortenPath(baseDir))
        folderLabel.setToolTipText(baseDir)
        
        // مدیریت فعال/غیرفعال شدن دکمه انتخاب پوشه (شامل Root)
