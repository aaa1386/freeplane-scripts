@Field static SimpleMapCrawler mapCrawler

if (mapCrawler == null) {
    mapCrawler = new SimpleMapCrawler()
    mapCrawler.toggle()
    return
}
mapCrawler.toggle()

class SimpleMapCrawler {
    private JTextField searchField
    private JTable resultsTable
    private DefaultTableModel tableModel
    private String baseDir
    private boolean matchCase = false
    private boolean wholeWord = false
    private JCheckBox coreCheck, detailsCheck, noteCheck
    private JRadioButton folderRadio, openMapsRadio
    private JRadioButton allScopeRadio, styleScopeRadio
    private JTextField styleField
    private JButton folderChooserBtn
    private JLabel folderLabel
    private JCheckBox matchCaseCB, wholeWordCB
    
    // Preview components
    private JTextArea previewCore
    private JTextArea previewDetails
    private JTextArea previewNote
    private JPanel tagViewer
    private JPanel breadcrumbPanel
    private JLabel styleLabel
    private ScrollableTextPanel textPanel
    private JPanel leftPreviewPanel
    private JSplitPane innerSplitPane
    
    private static final Map<String, Color> PATH_COLORS = new HashMap()
    private Container originalContentPane = null
    private JSplitPane currentSplitPane = null
    private int lastDividerLocation = -1
    
    // تنظیمات
    private boolean disableTooltips = false
    private boolean hideNodeColumn = false
    private boolean hideDetailsPreview = false
    private boolean hideNotePreview = false
    private boolean showFullNodeText = false
    private boolean hidePreviewPanel = false
    private TableColumn nodeColumn = null
    private JDialog settingsDialog = null
    private int lastPreviewDividerLocation = -1
    
    void toggle() {
        if (currentSplitPane == null) {
            show()
        } else {
            toggleExpandCollapse()
        }
    }
    
    void show() {
        def mainFrame = UITools.getCurrentFrame()
        if (currentSplitPane != null) return
        
        if (originalContentPane == null) {
            originalContentPane = mainFrame.getContentPane()
        }
        
        loadSettings()
        JPanel searchPanel = createSearchPanel()
        currentSplitPane = new JSplitPane(JSplitPane.HORIZONTAL_SPLIT,
                                          originalContentPane,
                                          searchPanel)
        currentSplitPane.setResizeWeight(0.75)
        currentSplitPane.setOneTouchExpandable(true)
        currentSplitPane.setContinuousLayout(false)
        currentSplitPane.setDividerSize(10)
        mainFrame.setContentPane(currentSplitPane)
        mainFrame.revalidate()
        mainFrame.repaint()
        
        currentSplitPane.addPropertyChangeListener("dividerLocation", new PropertyChangeListener() {
            void propertyChange(PropertyChangeEvent evt) {
                int max = currentSplitPane.getMaximumDividerLocation()
                int current = currentSplitPane.getDividerLocation()
                if (current < max - 5) {
                    lastDividerLocation = current
                }
            }
        })
        
        focusSearchField()
        setupKeyboardShortcut()
        applySettings()
    }
    
    private void closePanel() {
        if (currentSplitPane == null) return
        if (settingsDialog != null && settingsDialog.isVisible()) settingsDialog.dispose()
        def mainFrame = UITools.getCurrentFrame()
        if (originalContentPane != null) {
            mainFrame.setContentPane(originalContentPane)
            mainFrame.revalidate()
            mainFrame.repaint()
        }
        currentSplitPane = null
    }
    
    private void toggleExpandCollapse() {
        if (currentSplitPane == null) return
        int max = currentSplitPane.getMaximumDividerLocation()
        int current = currentSplitPane.getDividerLocation()
        if (current >= max - 5) {
            int target = (lastDividerLocation > 0 && lastDividerLocation < max) ? lastDividerLocation : (int)(currentSplitPane.getWidth() * 0.75)
            currentSplitPane.setDividerLocation(target)
        } else {
            lastDividerLocation = current
            currentSplitPane.setDividerLocation(1.0)
        }
    }
    
    private void setupKeyboardShortcut() {
        if (currentSplitPane == null) return
        def mainFrame = UITools.getCurrentFrame()
        mainFrame.getRootPane().getInputMap(JComponent.WHEN_IN_FOCUSED_WINDOW).put(
            KeyStroke.getKeyStroke(KeyEvent.VK_J, InputEvent.ALT_DOWN_MASK), "toggleCollapse")
        mainFrame.getRootPane().getActionMap().put("toggleCollapse", new AbstractAction() {
            void actionPerformed(ActionEvent e) { toggleExpandCollapse() }
        })
    }
    
    private JPanel createSearchPanel() {
        JPanel mainPanel = new JPanel(new BorderLayout())
        mainPanel.setMinimumSize(new Dimension(50, 0))
        
        // ========== خط اول ==========
        JPanel firstLine = new JPanel(new GridBagLayout())
        firstLine.setComponentOrientation(ComponentOrientation.LEFT_TO_RIGHT)
        GridBagConstraints gbc = new GridBagConstraints()
        gbc.insets = new Insets(2, 2, 2, 2)
        gbc.fill = GridBagConstraints.HORIZONTAL
        gbc.weightx = 0
        gbc.anchor = GridBagConstraints.WEST
        
        coreCheck = new JCheckBox("Core", true)
        detailsCheck = new JCheckBox("Details", false)
        noteCheck = new JCheckBox("Note", false)
        gbc.gridx = 0; firstLine.add(coreCheck, gbc)
        gbc.gridx = 1; firstLine.add(detailsCheck, gbc)
        gbc.gridx = 2; firstLine.add(noteCheck, gbc)
        
        searchField = new JTextField(20)
        searchField.setComponentOrientation(ComponentOrientation.RIGHT_TO_LEFT)
        searchField.setToolTipText("")
        searchField.addCaretListener({ e -> searchField.setToolTipText(searchField.getText()) })
        gbc.gridx = 3; gbc.weightx = 1.0; gbc.fill = GridBagConstraints.HORIZONTAL
        firstLine.add(searchField, gbc)
        
        JButton searchBtn = new JButton("🔍")
        gbc.gridx = 4; gbc.weightx = 0
        firstLine.add(searchBtn, gbc)
        
        // ========== خط دوم ==========
        JPanel secondLine = new JPanel(new GridBagLayout())
        secondLine.setComponentOrientation(ComponentOrientation.LEFT_TO_RIGHT)
        gbc = new GridBagConstraints()
        gbc.insets = new Insets(2, 2, 2, 2)
        gbc.fill = GridBagConstraints.HORIZONTAL
        gbc.weightx = 0
        gbc.anchor = GridBagConstraints.WEST
        
        folderRadio = new JRadioButton("Folder", true)
        openMapsRadio = new JRadioButton("Open Maps")
        ButtonGroup sourceGroup = new ButtonGroup()
        sourceGroup.add(folderRadio)
        sourceGroup.add(openMapsRadio)
        folderChooserBtn = new JButton("📁 Choose Folder")
        folderChooserBtn.addActionListener({ selectFolder() })
        folderLabel = new JLabel(shortenPath(baseDir))
        folderLabel.setToolTipText(baseDir)
        
        folderRadio.addActionListener({ e -> 
            folderChooserBtn.setEnabled(true)
            folderLabel.setEnabled(true)
        })
        openMapsRadio.addActionListener({ e -> 
            folderChooserBtn.setEnabled(false)
            folderLabel.setEnabled(false)
        })
        
        int col = 0
        gbc.gridx = col++; secondLine.add(folderRadio, gbc)
        gbc.gridx = col++; secondLine.add(openMapsRadio, gbc)
        gbc.gridx = col++; secondLine.add(folderChooserBtn, gbc)
        gbc.gridx = col++; secondLine.add(folderLabel, gbc)
        gbc.gridx = col++; secondLine.add(new JSeparator(SwingConstants.VERTICAL), gbc)
        
        allScopeRadio = new JRadioButton("All", true)
        styleScopeRadio = new JRadioButton("Style")
        ButtonGroup scopeGroup = new ButtonGroup()
        scopeGroup.add(allScopeRadio)
        scopeGroup.add(styleScopeRadio)
        styleField = new JTextField(8)
        styleField.setEnabled(false)
        styleField.setComponentOrientation(ComponentOrientation.LEFT_TO_RIGHT)
        styleField.setToolTipText("")
        styleField.addCaretListener({ e -> styleField.setToolTipText(styleField.getText()) })
        styleScopeRadio.addActionListener({ styleField.setEnabled(styleScopeRadio.isSelected()) })
        allScopeRadio.addActionListener({ styleField.setEnabled(false); styleField.setText("") })
        
        gbc.gridx = col++; secondLine.add(allScopeRadio, gbc)
        gbc.gridx = col++; secondLine.add(styleScopeRadio, gbc)
        gbc.gridx = col++; gbc.weightx = 1.0; gbc.fill = GridBagConstraints.HORIZONTAL
        secondLine.add(styleField, gbc)
        
        matchCaseCB = new JCheckBox("AA")
        matchCaseCB.addActionListener({ matchCase = matchCaseCB.isSelected() })
        wholeWordCB = new JCheckBox("WW")
        wholeWordCB.addActionListener({ wholeWord = wholeWordCB.isSelected() })
        gbc.gridx = col++; gbc.weightx = 0; secondLine.add(matchCaseCB, gbc)
        gbc.gridx = col++; secondLine.add(wholeWordCB, gbc)
        
        JPanel topPanel = new JPanel(new GridLayout(2, 1, 0, 2))
        topPanel.add(firstLine)
        topPanel.add(secondLine)
        
        // ========== Breadcrumb با جهت‌گیری راست به چپ کامل ==========
        breadcrumbPanel = new JPanel()
        breadcrumbPanel.setLayout(new BoxLayout(breadcrumbPanel, BoxLayout.LINE_AXIS))
        breadcrumbPanel.setComponentOrientation(ComponentOrientation.RIGHT_TO_LEFT)
        breadcrumbPanel.setBackground(UIManager.getColor("Panel.background"))
        
        // ========== Preview Panel ==========
        leftPreviewPanel = new JPanel(new BorderLayout())
        leftPreviewPanel.setBorder(BorderFactory.createEmptyBorder())
        
        JPanel topPreviewPanel = new JPanel(new BorderLayout())
        topPreviewPanel.setBackground(leftPreviewPanel.getBackground())
        topPreviewPanel.setBorder(BorderFactory.createEmptyBorder())
        
        styleLabel = new JLabel()
        styleLabel.setFont(styleLabel.getFont().deriveFont(Font.ITALIC, 10f))
        styleLabel.setForeground(Color.GRAY)
        styleLabel.setHorizontalAlignment(SwingConstants.RIGHT)
        styleLabel.setComponentOrientation(ComponentOrientation.RIGHT_TO_LEFT)
        topPreviewPanel.add(styleLabel, BorderLayout.NORTH)
        
        tagViewer = new JPanel(new FlowLayout(FlowLayout.LEFT, 5, 5))
        tagViewer.setBackground(leftPreviewPanel.getBackground())
        tagViewer.setComponentOrientation(ComponentOrientation.RIGHT_TO_LEFT)
        topPreviewPanel.add(tagViewer, BorderLayout.CENTER)
        
        previewCore = new JTextArea()
        previewCore.setEditable(false)
        previewCore.setLineWrap(true)
        previewCore.setWrapStyleWord(true)
        previewCore.setMargin(new Insets(10,10,10,10))
        previewCore.setComponentOrientation(ComponentOrientation.RIGHT_TO_LEFT)
        Font defaultFont = UIManager.getFont("Label.font")
        previewCore.setFont(defaultFont.deriveFont( (float)(defaultFont.getSize() + 4) ))
        
        previewDetails = new JTextArea()
        previewDetails.setEditable(false)
        previewDetails.setLineWrap(true)
        previewDetails.setWrapStyleWord(true)
        previewDetails.setMargin(new Insets(10,10,10,10))
        previewDetails.setComponentOrientation(ComponentOrientation.RIGHT_TO_LEFT)
        previewDetails.setFont(defaultFont.deriveFont(Font.ITALIC))
        
        previewNote = new JTextArea()
        previewNote.setEditable(false)
        previewNote.setLineWrap(true)
        previewNote.setWrapStyleWord(true)
        previewNote.setMargin(new Insets(10,10,10,10))
        previewNote.setComponentOrientation(ComponentOrientation.RIGHT_TO_LEFT)
        previewNote.setFont(defaultFont)
        
        textPanel = new ScrollableTextPanel()
        textPanel.add(previewCore)
        textPanel.add(Box.createRigidArea(new Dimension(0, 10)))
        textPanel.add(previewDetails)
        textPanel.add(Box.createRigidArea(new Dimension(0, 10)))
        textPanel.add(previewNote)
        
        JScrollPane previewScroll = new JScrollPane(textPanel)
        previewScroll.setBorder(BorderFactory.createEmptyBorder())
        previewScroll.setViewportBorder(BorderFactory.createEmptyBorder())
        previewScroll.setComponentOrientation(ComponentOrientation.LEFT_TO_RIGHT)
        previewScroll.getViewport().setComponentOrientation(ComponentOrientation.LEFT_TO_RIGHT)
        previewScroll.setHorizontalScrollBarPolicy(JScrollPane.HORIZONTAL_SCROLLBAR_NEVER)
        
        previewScroll.addComponentListener(new ComponentAdapter() {
            void componentResized(ComponentEvent e) {
                SwingUtilities.invokeLater({
                    textPanel.revalidate()
                    previewScroll.revalidate()
                })
            }
        })
        
        leftPreviewPanel.add(topPreviewPanel, BorderLayout.NORTH)
        leftPreviewPanel.add(previewScroll, BorderLayout.CENTER)
        
        // ========== Table Results ==========
        tableModel = new DefaultTableModel(["File", "Style", "Node"] as Object[], 0)
        resultsTable = new JTable(tableModel)
        resultsTable.setComponentOrientation(ComponentOrientation.RIGHT_TO_LEFT)
        resultsTable.getTableHeader().setComponentOrientation(ComponentOrientation.RIGHT_TO_LEFT)
        resultsTable.setShowHorizontalLines(true)
        resultsTable.setShowVerticalLines(true)
        resultsTable.setIntercellSpacing(new Dimension(1, 1))
        
        TableRowSorter<TableModel> sorter = new TableRowSorter<>(tableModel)
        sorter.setComparator(2, new Comparator<Object>() {
            int compare(Object o1, Object o2) {
                String s1 = getNodeTextFromValue(o1)
                String s2 = getNodeTextFromValue(o2)
                if (s1 == null) return (s2 == null) ? 0 : -1
                if (s2 == null) return 1
                return s1.compareTo(s2)
            }
        })
        resultsTable.setRowSorter(sorter)
        
        DefaultTableCellRenderer rightRenderer = new DefaultTableCellRenderer()
        rightRenderer.setHorizontalAlignment(SwingConstants.RIGHT)
        resultsTable.getColumnModel().getColumn(0).setCellRenderer(rightRenderer)
        resultsTable.getColumnModel().getColumn(1).setCellRenderer(rightRenderer)
        resultsTable.getColumnModel().getColumn(2).setCellRenderer(new NodeCellWrapRenderer())
        
        resultsTable.setAutoResizeMode(JTable.AUTO_RESIZE_ALL_COLUMNS)
        resultsTable.getColumnModel().getColumn(0).setPreferredWidth(150)
        resultsTable.getColumnModel().getColumn(1).setPreferredWidth(100)
        resultsTable.getColumnModel().getColumn(2).setPreferredWidth(400)
        resultsTable.getColumnModel().getColumn(0).setMinWidth(80)
        resultsTable.getColumnModel().getColumn(1).setMinWidth(60)
        resultsTable.setDefaultEditor(Object, null)
        
        resultsTable.getSelectionModel().addListSelectionListener({ e ->
            if (e.getValueIsAdjusting()) return
            int row = resultsTable.getSelectedRow()
            if (row != -1) showNodeDetails(row)
            else clearPreview()
        })
        
        resultsTable.addMouseListener(new MouseAdapter() {
            void mouseClicked(MouseEvent e) {
                if (e.clickCount == 2) {
                    int row = resultsTable.selectedRow
                    if (row != -1) goToNode(row)
                }
            }
        })
        resultsTable.addKeyListener(new KeyAdapter() {
            void keyPressed(KeyEvent e) {
                if (e.keyCode == KeyEvent.VK_ENTER) {
                    int row = resultsTable.selectedRow
                    if (row != -1) goToNode(row)
                }
            }
        })
        
        JScrollPane tableScroll = new JScrollPane(resultsTable)
        tableScroll.setComponentOrientation(ComponentOrientation.RIGHT_TO_LEFT)
        tableScroll.setHorizontalScrollBarPolicy(JScrollPane.HORIZONTAL_SCROLLBAR_NEVER)
        
        innerSplitPane = new JSplitPane(JSplitPane.HORIZONTAL_SPLIT, leftPreviewPanel, tableScroll)
        innerSplitPane.setResizeWeight(0.35)
        innerSplitPane.setContinuousLayout(false)
        innerSplitPane.setDividerSize(6)
        
        JPanel centerPanel = new JPanel(new BorderLayout())
        centerPanel.add(breadcrumbPanel, BorderLayout.NORTH)
        centerPanel.add(innerSplitPane, BorderLayout.CENTER)
        
        mainPanel.add(topPanel, BorderLayout.NORTH)
        mainPanel.add(centerPanel, BorderLayout.CENTER)
        
        // ========== نوار وضعیت با دکمه تنظیمات جدید ==========
        JPanel statusBar = new JPanel(new FlowLayout(FlowLayout.LEFT))
        statusBar.setComponentOrientation(ComponentOrientation.LEFT_TO_RIGHT)
        
        JButton closeBtn = new JButton("✖")
        closeBtn.setToolTipText("Close Search Panel")
        closeBtn.addActionListener({ closePanel() })
        statusBar.add(closeBtn)
        
        // دکمه تنظیمات با آیکن چرخ‌دنده و بدون حاشیه (مطابق کد نمونه)
        JButton settingsBtn = new JButton(MenuUtils.getMenuItemIcon('IconAction.' + "emoji-2699"))
        settingsBtn.setToolTipText("Settings")
        settingsBtn.setContentAreaFilled(false)
        settingsBtn.setBorderPainted(false)
        settingsBtn.setFocusPainted(false)
        settingsBtn.addActionListener({ showSettingsDialog() })
        statusBar.add(settingsBtn)
        
        statusBar.add(folderChooserBtn)
        statusBar.add(folderLabel)
        mainPanel.add(statusBar, BorderLayout.SOUTH)
        
        searchBtn.addActionListener({ doSearch() })
        searchField.addActionListener({ doSearch() })
        
        return mainPanel
    }
    
    // ======================= دیالوگ تنظیمات =======================
    private void showSettingsDialog() {
        if (settingsDialog != null && settingsDialog.isVisible()) {
            settingsDialog.toFront()
            return
        }
        settingsDialog = new JDialog(UITools.getCurrentFrame(), "Settings", true)
        settingsDialog.setLayout(new GridBagLayout())
        settingsDialog.setSize(600, 520)
        settingsDialog.setLocationRelativeTo(UITools.getCurrentFrame())
        
        GridBagConstraints gbc = new GridBagConstraints()
        gbc.insets = new Insets(8, 12, 8, 12)
        gbc.anchor = GridBagConstraints.WEST
        gbc.gridx = 0
        gbc.gridwidth = 2
        
        JCheckBox disableTooltipCheck = new JCheckBox("Disable tooltips on results", disableTooltips)
        settingsDialog.add(disableTooltipCheck, gbc)
        
        gbc.gridy = 1
        JCheckBox hideNodeColCheck = new JCheckBox("Hide 'Node' column", hideNodeColumn)
        settingsDialog.add(hideNodeColCheck, gbc)
        
        gbc.gridy = 2
        JCheckBox hideDetailsCheck = new JCheckBox("Hide Details preview", hideDetailsPreview)
        settingsDialog.add(hideDetailsCheck, gbc)
        
        gbc.gridy = 3
        JCheckBox hideNoteCheck = new JCheckBox("Hide Note preview", hideNotePreview)
        settingsDialog.add(hideNoteCheck, gbc)
        
        gbc.gridy = 4
        JCheckBox showFullNodeCheck = new JCheckBox("Show full node text (no truncation)", showFullNodeText)
        settingsDialog.add(showFullNodeCheck, gbc)
        
        gbc.gridy = 5
        JCheckBox hidePreviewPanelCheck = new JCheckBox("Hide node preview panel (left panel)", hidePreviewPanel)
        settingsDialog.add(hidePreviewPanelCheck, gbc)
        
        gbc.gridy = 6
        gbc.gridwidth = 1
        JButton saveBtn = new JButton("Save")
        JButton cancelBtn = new JButton("Cancel")
        JPanel btnPanel = new JPanel(new FlowLayout(FlowLayout.CENTER))
        btnPanel.add(saveBtn)
        btnPanel.add(cancelBtn)
        settingsDialog.add(btnPanel, gbc)
        
        saveBtn.addActionListener({ e ->
            disableTooltips = disableTooltipCheck.isSelected()
            hideNodeColumn = hideNodeColCheck.isSelected()
            hideDetailsPreview = hideDetailsCheck.isSelected()
            hideNotePreview = hideNoteCheck.isSelected()
            showFullNodeText = showFullNodeCheck.isSelected()
            hidePreviewPanel = hidePreviewPanelCheck.isSelected()
            saveSettingsToPrefs()
            applySettings()
            settingsDialog.dispose()
        })
        cancelBtn.addActionListener({ e -> settingsDialog.dispose() })
        
        settingsDialog.setVisible(true)
    }
    
    private void saveSettingsToPrefs() {
        def rc = ResourceController.getResourceController()
        rc.setProperty("mapcrawler.disableTooltips", String.valueOf(disableTooltips))
        rc.setProperty("mapcrawler.hideNodeColumn", String.valueOf(hideNodeColumn))
        rc.setProperty("mapcrawler.hideDetailsPreview", String.valueOf(hideDetailsPreview))
        rc.setProperty("mapcrawler.hideNotePreview", String.valueOf(hideNotePreview))
        rc.setProperty("mapcrawler.showFullNodeText", String.valueOf(showFullNodeText))
        rc.setProperty("mapcrawler.hidePreviewPanel", String.valueOf(hidePreviewPanel))
    }
    
    private void loadSettings() {
        def rc = ResourceController.getResourceController()
        String savedDir = rc.getProperty("mapcrawler.lastUsedDir")
        baseDir = (savedDir != null && new File(savedDir).exists()) ? savedDir : "D:\\AJ\\OneDrive\\FP"
        disableTooltips = "true".equals(rc.getProperty("mapcrawler.disableTooltips"))
        hideNodeColumn = "true".equals(rc.getProperty("mapcrawler.hideNodeColumn"))
        hideDetailsPreview = "true".equals(rc.getProperty("mapcrawler.hideDetailsPreview"))
        hideNotePreview = "true".equals(rc.getProperty("mapcrawler.hideNotePreview"))
        showFullNodeText = "true".equals(rc.getProperty("mapcrawler.showFullNodeText"))
        hidePreviewPanel = "true".equals(rc.getProperty("mapcrawler.hidePreviewPanel"))
    }
    
    private void applySettings() {
        if (resultsTable == null) return
        // ستون Node
        TableColumnModel colModel = resultsTable.getColumnModel()
        for (int i = 0; i < colModel.getColumnCount(); i++) {
            TableColumn col = colModel.getColumn(i)
            if (col.getHeaderValue() == "Node") {
                nodeColumn = col
                break
            }
        }
        if (hideNodeColumn && nodeColumn != null) {
            nodeColumn.setMinWidth(0)
            nodeColumn.setMaxWidth(0)
            nodeColumn.setWidth(0)
            nodeColumn.setPreferredWidth(0)
            resultsTable.getTableHeader().getColumnModel().getColumn(2).setMaxWidth(0)
        } else if (nodeColumn != null) {
            nodeColumn.setMinWidth(80)
            nodeColumn.setMaxWidth(Integer.MAX_VALUE)
            nodeColumn.setWidth(400)
            nodeColumn.setPreferredWidth(400)
            resultsTable.getTableHeader().getColumnModel().getColumn(2).setMaxWidth(Integer.MAX_VALUE)
        }
        
        // مخفی کردن Details/Note preview
        if (previewDetails != null && previewNote != null && textPanel != null) {
            Component[] comps = textPanel.getComponents()
            boolean detailsVisible = !hideDetailsPreview
            boolean noteVisible = !hideNotePreview
            for (Component c : comps) {
                if (c == previewDetails) c.setVisible(detailsVisible)
                else if (c == previewNote) c.setVisible(noteVisible)
            }
            textPanel.revalidate()
            textPanel.repaint()
        }
        
        // مخفی کردن کل پنل پیش‌نمایش (سمت چپ)
        if (innerSplitPane != null && leftPreviewPanel != null) {
            if (hidePreviewPanel) {
                if (leftPreviewPanel.isVisible() && lastPreviewDividerLocation == -1) {
                    lastPreviewDividerLocation = innerSplitPane.getDividerLocation()
                }
                leftPreviewPanel.setVisible(false)
                innerSplitPane.setDividerLocation(0)
                innerSplitPane.setDividerSize(0)
            } else {
                leftPreviewPanel.setVisible(true)
                innerSplitPane.setDividerSize(6)
                if (lastPreviewDividerLocation > 0 && lastPreviewDividerLocation < innerSplitPane.getMaximumDividerLocation()) {
                    innerSplitPane.setDividerLocation(lastPreviewDividerLocation)
                } else {
                    innerSplitPane.setDividerLocation(0.35)
                }
            }
            innerSplitPane.revalidate()
            innerSplitPane.repaint()
        }
        
        resultsTable.repaint()
    }
    
    // ========== متدهای کمکی ==========
    private String getNodeTextFromValue(Object value) {
        Node node = null
        if (value instanceof Object[] && ((Object[]) value).length > 0) {
            node = ((Object[]) value)[0] as Node
        } else if (value instanceof Node) {
            node = value as Node
        }
        return node?.plainText ?: ""
    }
    
    private void selectFolder() {
        JFileChooser fc = new JFileChooser()
        fc.setFileSelectionMode(JFileChooser.DIRECTORIES_ONLY)
        fc.setDialogTitle("Select Folder containing .mm files")
        if (new File(baseDir).exists()) fc.setCurrentDirectory(new File(baseDir))
        if (fc.showOpenDialog(UITools.getCurrentFrame()) == JFileChooser.APPROVE_OPTION) {
            baseDir = fc.getSelectedFile().absolutePath
            folderLabel.setText(shortenPath(baseDir))
            folderLabel.setToolTipText(baseDir)
            saveSettings()
            tableModel.setRowCount(0)
            clearPreview()
        }
    }
    
    private void saveSettings() {
        ResourceController.getResourceController().setProperty("mapcrawler.lastUsedDir", baseDir)
        saveSettingsToPrefs()
    }
    
    private String shortenPath(String path) {
        if (path.length() <= 40) return path
        return "..." + path.substring(path.length() - 37)
    }
    
    private void clearPreview() {
        tagViewer.removeAll()
        styleLabel.setText("")
        previewCore.setText("")
        previewDetails.setText("")
        previewNote.setText("")
        breadcrumbPanel.removeAll()
        textPanel.revalidate()
        textPanel.repaint()
        tagViewer.revalidate()
        tagViewer.repaint()
        breadcrumbPanel.revalidate()
        breadcrumbPanel.repaint()
    }
    
    private void showNodeDetails(int row) {
    int modelRow = resultsTable.convertRowIndexToModel(row)
    Object value = tableModel.getValueAt(modelRow, 2)
    Node node = (value instanceof Object[]) ? ((Object[])value)[0] as Node : (value instanceof Node ? value as Node : null)
    if (node == null) { clearPreview(); return }
    
    NodeModel nodeModel = getNodeModel(node)
    String styleName = node.getStyle()?.getName()
    styleLabel.setText(styleName ? "Style: " + styleName : "")
    
    tagViewer.removeAll()
    def icons = iconController().getIcons(nodeModel, org.freeplane.features.styles.LogicalStyleController.StyleOption.FOR_UNSELECTED_NODE)
    def tags = iconController().getTagIcons(nodeModel)
    for (NamedIcon ic : icons) tagViewer.add(new JLabel(ic.getIcon()))
    for (TagIcon tg : tags) tagViewer.add(new JLabel(tg))
    tagViewer.revalidate()
    tagViewer.repaint()
    
    previewCore.setText(node.getPlainText() ?: "")
    previewDetails.setText(node.getDetails()?.getPlain() ?: "")
    previewNote.setText(node.getNote()?.getPlain() ?: "")
    textPanel.revalidate()
    textPanel.repaint()
    
    // ========== ساخت Breadcrumb با رادیو باتن و رنگ آبی هنگام کلیک ==========
    breadcrumbPanel.removeAll()
    java.util.List<Node> fullPath = node.getPathToRoot()
    int maxNodes = 5
    int start = Math.max(0, fullPath.size() - maxNodes)
    
    JPanel tempPanel = new JPanel()
    tempPanel.setLayout(new BoxLayout(tempPanel, BoxLayout.LINE_AXIS))
    tempPanel.setComponentOrientation(ComponentOrientation.RIGHT_TO_LEFT)
    
    if (start > 0) {
        JLabel ellipsisLabel = new JLabel(" ... ")
        ellipsisLabel.setFont(ellipsisLabel.getFont().deriveFont(Font.BOLD))
        tempPanel.add(ellipsisLabel)
    }
    
    ButtonGroup bg = new ButtonGroup()
    for (int i = start; i < fullPath.size(); i++) {
        Node n = fullPath.get(i)
        String shortText = TextUtils.getShortText(n.getPlainText(), 20, "\u2026")
        JRadioButton btn = new JRadioButton(shortText)
        btn.setToolTipText(n.getPlainText())
        btn.setFont(btn.getFont().deriveFont(Font.PLAIN))
        btn.setBorder(BorderFactory.createEmptyBorder(2, 6, 2, 6))
        btn.setOpaque(false)
        btn.setComponentOrientation(ComponentOrientation.RIGHT_TO_LEFT)
        btn.setHorizontalAlignment(SwingConstants.RIGHT)
        btn.setHorizontalTextPosition(SwingConstants.LEFT)
        
        // همه دکمه‌ها ابتدا رنگ عادی دارند
        btn.setForeground(UIManager.getColor("Label.foreground"))
        btn.putClientProperty("node", n)
        
        final Node target = n
        final JRadioButton currentBtn = btn
        btn.addActionListener({ e ->
            // 1) همه دکمه‌های موجود در tempPanel را به حالت عادی برگردان
            for (Component comp : tempPanel.getComponents()) {
                if (comp instanceof JRadioButton) {
                    JRadioButton rb = (JRadioButton) comp
                    rb.setForeground(UIManager.getColor("Label.foreground"))
                    rb.setFont(rb.getFont().deriveFont(Font.PLAIN))
                }
            }
            // 2) دکمه کلیک شده را آبی و توپر کن
            currentBtn.setForeground(Color.BLUE)
            currentBtn.setFont(currentBtn.getFont().deriveFont(Font.BOLD))
            // 3) ناوبری
            try {
                ScriptUtils.c().select(target)
                def mapFile = target.getMindMap().getFile()
                if (mapFile) {
                    def uri = mapFile.toURI().toString() + "#" + target.getId()
                    def link = new org.freeplane.core.util.Hyperlink(new URI(uri))
                    org.freeplane.features.url.UrlManager.getController().loadHyperlink(link)
                }
            } catch (Exception ex) { ex.printStackTrace() }
        })
        tempPanel.add(btn)
        bg.add(btn)
    }
    
    // انتخاب رادیو باتن متناظر با گره جاری (هیچ رنگی به آن اختصاص نمی‌یابد)
    for (Component comp : tempPanel.getComponents()) {
        if (comp instanceof JRadioButton) {
            JRadioButton rb = (JRadioButton) comp
            Node storedNode = (Node) rb.getClientProperty("node")
            if (storedNode == node) {
                rb.setSelected(true)
                break
            }
        }
    }
    
    breadcrumbPanel.add(tempPanel, BorderLayout.CENTER)
    breadcrumbPanel.revalidate()
    breadcrumbPanel.repaint()
    }
    
    private void doSearch() {
        String keyword = searchField.text.trim()
        if (keyword.isEmpty()) return
        
        boolean searchCore = coreCheck.selected
        boolean searchDetails = detailsCheck.selected
        boolean searchNote = noteCheck.selected
        if (!searchCore && !searchDetails && !searchNote) {
            JOptionPane.showMessageDialog(UITools.getCurrentFrame(), "Select at least one search option")
            return
        }
        
        def styleNames = []
        if (styleScopeRadio.selected) {
            String raw = styleField.text.trim()
            if (raw.isEmpty()) {
                JOptionPane.showMessageDialog(UITools.getCurrentFrame(), "Enter style name")
                return
            }
            styleNames = raw.split(/[;,\\.]+/).collect{ it.trim() }.findAll{ !it.isEmpty() }
            if (styleNames.isEmpty()) {
                JOptionPane.showMessageDialog(UITools.getCurrentFrame(), "Enter valid style name(s)")
                return
            }
        }
        
        tableModel.setRowCount(0)
        clearPreview()
        
        def maps = []
        if (folderRadio.selected) {
            File dir = new File(baseDir)
            if (!dir.exists() || !dir.isDirectory()) {
                JOptionPane.showMessageDialog(UITools.getCurrentFrame(), "Invalid folder: $baseDir")
                return
            }
            def files = dir.listFiles().findAll { it.name.endsWith(".mm") }
            if (files.isEmpty()) {
                JOptionPane.showMessageDialog(UITools.getCurrentFrame(), "No .mm files found")
                return
            }
            files.each { file ->
                try { maps << ScriptUtils.c().mapLoader(file).mindMap }
                catch (Exception e) { println "Error loading $file.name: $e.message" }
            }
        } else {
            maps = ScriptUtils.c().openMindMaps
            if (maps.isEmpty()) { JOptionPane.showMessageDialog(UITools.getCurrentFrame(), "No open maps"); return }
        }
        
        if (maps.isEmpty()) { JOptionPane.showMessageDialog(UITools.getCurrentFrame(), "No maps to search"); return }
        
        int resultCount = 0
        for (def map : maps) {
            try {
                map.root.findAll().each { node ->
                    if (isMatch(node, keyword, styleNames, searchCore, searchDetails, searchNote)) {
                        resultCount++
                        String fileName = map.file?.name ?: "Unnamed"
                        String styleName = node.style?.name ?: "(no style)"
                        tableModel.addRow([ fileName, styleName, [node] as Object[] ] as Object[])
                        String pathKey = map.file?.absolutePath ?: "unsaved"
                        if (!PATH_COLORS.containsKey(pathKey)) PATH_COLORS.put(pathKey, determineStringColor(pathKey))
                    }
                }
            } catch (Exception e) { println "Error in map ${map.file?.name}: $e.message" }
        }
        if (resultCount == 0) JOptionPane.showMessageDialog(UITools.getCurrentFrame(), "No results found")
    }
    
    private boolean isMatch(Node node, String keyword, def styleNames,
                            boolean searchCore, boolean searchDetails, boolean searchNote) {
        if (styleScopeRadio.selected && styleNames) {
            String nodeStyle = node.style?.name
            if (!nodeStyle || !styleNames.contains(nodeStyle)) return false
        }
        String kw = matchCase ? keyword : keyword.toLowerCase()
        if (searchCore) {
            String text = node.plainText ?: ""
            if (!matchCase) text = text.toLowerCase()
            if (wholeWord ? text ==~ /.*\b$kw\b.*/ : text.contains(kw)) return true
        }
        if (searchDetails && node.details?.plain) {
            String text = node.details.plain
            if (!matchCase) text = text.toLowerCase()
            if (wholeWord ? text ==~ /.*\b$kw\b.*/ : text.contains(kw)) return true
        }
        if (searchNote && node.note?.plain) {
            String text = node.note.plain
            if (!matchCase) text = text.toLowerCase()
            if (wholeWord ? text ==~ /.*\b$kw\b.*/ : text.contains(kw)) return true
        }
        return false
    }
    
    private void goToNode(int row) {
        int modelRow = resultsTable.convertRowIndexToModel(row)
        Object value = tableModel.getValueAt(modelRow, 2)
        Node node = (value instanceof Object[]) ? ((Object[])value)[0] as Node : (value instanceof Node ? value as Node : null)
        if (node != null) {
            try {
                ScriptUtils.c().select(node)
                def mapFile = node.mindMap.file
                if (mapFile) {
                    def uri = mapFile.toURI().toString() + "#" + node.id
                    def link = new org.freeplane.core.util.Hyperlink(new URI(uri))
                    org.freeplane.features.url.UrlManager.getController().loadHyperlink(link)
                }
            } catch (Exception e) {
                e.printStackTrace()
                JOptionPane.showMessageDialog(UITools.getCurrentFrame(), "Error navigating to node: ${e.message}")
            }
        }
    }
    
    private void focusSearchField() {
        SwingUtilities.invokeLater({
            if (searchField != null) { searchField.requestFocusInWindow(); searchField.selectAll() }
        })
    }
    
    // ======================= کلاس‌های داخلی =======================
    class NodeCellWrapRenderer extends JTextArea implements TableCellRenderer {
        NodeCellWrapRenderer() {
            setLineWrap(true); setWrapStyleWord(true); setMargin(new Insets(5,5,5,5)); setOpaque(true)
            setBorder(BorderFactory.createEmptyBorder(2,2,2,2))
        }
        public Component getTableCellRendererComponent(JTable table, Object value, boolean isSelected, boolean hasFocus, int row, int col) {
            Node node = (value instanceof Object[]) ? ((Object[])value)[0] as Node : (value instanceof Node ? value as Node : null)
            String displayText = node?.plainText ?: ""
            if (!showFullNodeText) {
                displayText = TextUtils.getShortText(displayText, 80, "\u2026")
            }
            setText(displayText)
            if (!disableTooltips) {
                setToolTipText(node?.plainText ?: "")
            } else {
                setToolTipText(null)
            }
            Color borderColor = Color.GRAY
            if (node?.mindMap?.file) {
                String path = node.mindMap.file.absolutePath
                if (PATH_COLORS.containsKey(path)) borderColor = PATH_COLORS.get(path)
            }
            setBorder(BorderFactory.createCompoundBorder(
                BorderFactory.createMatteBorder(0,5,0,0, borderColor),
                BorderFactory.createEmptyBorder(0,10,0,10)))
            setBackground(isSelected ? table.getSelectionBackground() : table.getBackground())
            setForeground(isSelected ? table.getSelectionForeground() : table.getForeground())
            setFont(table.getFont())
            setSize(table.getColumnModel().getColumn(col).getWidth(), Short.MAX_VALUE)
            int prefHeight = getPreferredSize().height + 10
            if (table.getRowHeight(row) != prefHeight) table.setRowHeight(row, prefHeight)
            return this
        }
    }
    
    class ScrollableTextPanel extends JPanel implements Scrollable {
        ScrollableTextPanel() {
            setLayout(new BoxLayout(this, BoxLayout.Y_AXIS))
            setBorder(BorderFactory.createEmptyBorder())
            setComponentOrientation(ComponentOrientation.RIGHT_TO_LEFT)
        }
        boolean getScrollableTracksViewportWidth() { return true }
        boolean getScrollableTracksViewportHeight() { return false }
        Dimension getPreferredScrollableViewportSize() { return getPreferredSize() }
        int getScrollableUnitIncrement(Rectangle visibleRect, int orientation, int direction) { return 10 }
        int getScrollableBlockIncrement(Rectangle visibleRect, int orientation, int direction) {
            return orientation == SwingConstants.VERTICAL ? visibleRect.height : visibleRect.width
        }
    }
    
    private static MIconController iconController() {
        return (MIconController) getModeController().getExtension(IconController.class)
    }
    private static MModeController getModeController() { return MModeController.getMModeController() }
    private static NodeModel getNodeModel(Node node) {
        return ((MapProxy) node.getMindMap()).getDelegate().getNodeForID(node.getId())
    }
    private static Color determineStringColor(String str) {
        CRC32 crc = new CRC32()
        crc.update(str.getBytes(StandardCharsets.UTF_8))
        return HSLColorConverter.generateColorFromLong(crc.getValue())
    }
}
