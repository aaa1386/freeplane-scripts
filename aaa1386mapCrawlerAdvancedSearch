    private String getNodeTextFromValue(Object value) {
        Node node = null
        if (value instanceof Object[] && ((Object[]) value).length > 0) {
            node = ((Object[]) value)[0] as Node
        } else if (value instanceof Node) {
            node = value as Node
        }
        return node?.plainText ?: ""
    }
    
    private void loadSettings() {
        def rc = ResourceController.getResourceController()
        String saved = rc.getProperty("mapcrawler.lastUsedDir")
        if (saved != null && !saved.isEmpty() && new File(saved).exists()) {
            baseDir = saved
        } else {
            baseDir = "D:\\AJ\\OneDrive\\FP"
        }
    }
    
    private void saveSettings() {
        ResourceController.getResourceController().setProperty("mapcrawler.lastUsedDir", baseDir)
    }
    
    private void selectFolder() {
        JFileChooser fc = new JFileChooser()
        fc.setFileSelectionMode(JFileChooser.DIRECTORIES_ONLY)
        fc.setDialogTitle("انتخاب پوشه حاوی فایل‌های .mm")
        if (baseDir != null && new File(baseDir).exists()) {
            fc.setCurrentDirectory(new File(baseDir))
        }
        if (fc.showOpenDialog(frame) == JFileChooser.APPROVE_OPTION) {
            baseDir = fc.getSelectedFile().absolutePath
            folderLabel.setText(shortenPath(baseDir))
            folderLabel.setToolTipText(baseDir)
            saveSettings()
            tableModel.setRowCount(0)
            clearPreview()
        }
    }
    
    private String shortenPath(String path) {
        if (path.length() <= 40) return path
        return "..." + path.substring(path.length() - 37)
    }
    
    private void clearPreview() {
        tagViewer.removeAll()
        styleLabel.setText("")
        previewCore.setText("")
        previewDetails.setText("")
        previewNote.setText("")
        breadcrumbPanel.removeAll()
        resetTextAreaHeight(previewCore)
        resetTextAreaHeight(previewDetails)
        resetTextAreaHeight(previewNote)
        tagViewer.revalidate()
        tagViewer.repaint()
        breadcrumbPanel.revalidate()
        breadcrumbPanel.repaint()
    }
    
    private void adjustTextAreaHeight(JTextArea ta) {
        try {
            int lines = ta.getLineCount()
            if (lines == 0 || (lines == 1 && ta.getText().trim().isEmpty())) {
                ta.setRows(2)
            } else {
                ta.setRows(lines + 1)
            }
        } catch (Exception ex) { }
    }
    
    private void resetTextAreaHeight(JTextArea ta) {
        ta.setRows(2)
    }
    
    private void showNodeDetails(int row) {
        int modelRow = resultsTable.convertRowIndexToModel(row)
        Object value = tableModel.getValueAt(modelRow, 2)
        Node node = null
        if (value instanceof Object[] && ((Object[]) value).length > 0) {
            node = ((Object[]) value)[0] as Node
        } else if (value instanceof Node) {
            node = value as Node
        }
        if (node == null) {
            clearPreview()
            return
        }
        
        NodeModel nodeModel = getNodeModel(node)
        
        String styleName = node.getStyle()?.getName()
        styleLabel.setText(styleName != null && !styleName.isEmpty() ? "سبک: " + styleName : "")
        
        tagViewer.removeAll()
        def icons = iconController().getIcons(nodeModel, org.freeplane.features.styles.LogicalStyleController.StyleOption.FOR_UNSELECTED_NODE)
        def tags = iconController().getTagIcons(nodeModel)
        for (NamedIcon ic : icons) tagViewer.add(new JLabel(ic.getIcon()))
        for (TagIcon tg : tags) tagViewer.add(new JLabel(tg))
        tagViewer.revalidate()
        tagViewer.repaint()
        
        previewCore.setText(node.getPlainText() ?: "")
        previewDetails.setText(node.getDetails() != null ? node.getDetails().getPlain() : "")
        previewNote.setText(node.getNote() != null ? node.getNote().getPlain() : "")
        
        adjustTextAreaHeight(previewCore)
        adjustTextAreaHeight(previewDetails)
        adjustTextAreaHeight(previewNote)
        
        // ========== ساخت نوار ناوبری ==========
        breadcrumbPanel.removeAll()
        java.util.List<Node> fullPath = node.getPathToRoot()
        int maxNodes = 5
        java.util.List<Node> displayPath = new ArrayList<Node>()
        if (fullPath.size() <= maxNodes) {
            displayPath.addAll(fullPath)
        } else {
            displayPath.addAll(fullPath.subList(fullPath.size() - maxNodes, fullPath.size()))
            JLabel ellipsis = new JLabel(" ... ")
            ellipsis.setFont(ellipsis.getFont().deriveFont(Font.BOLD))
            breadcrumbPanel.add(ellipsis)
            JLabel arrow = new JLabel(" ← ")
            arrow.setFont(arrow.getFont().deriveFont(Font.BOLD))
            breadcrumbPanel.add(arrow)
        }
        
        ButtonGroup bg = new ButtonGroup()
        for (int i = 0; i < displayPath.size(); i++) {
            Node n = displayPath.get(i)
            String shortText = TextUtils.getShortText(n.getPlainText(), 20, "\u2026")
            JRadioButton btn = new JRadioButton(shortText)
            btn.setToolTipText(n.getPlainText())
            btn.setFont(btn.getFont().deriveFont(Font.PLAIN))
            btn.setBorder(BorderFactory.createEmptyBorder(2, 6, 2, 6))
            btn.setOpaque(false)
            btn.setComponentOrientation(ComponentOrientation.RIGHT_TO_LEFT)
            btn.setHorizontalTextPosition(SwingConstants.LEADING)
            final Node targetNode = n
            btn.addActionListener({ e ->
                try {
                    ScriptUtils.c().select(targetNode)
                    def mapFile = targetNode.getMindMap().getFile()
                    if (mapFile) {
                        def uri = mapFile.toURI().toString() + "#" + targetNode.getId()
                        def link = new org.freeplane.core.util.Hyperlink(new URI(uri))
                        org.freeplane.features.url.UrlManager.getController().loadHyperlink(link)
                    }
                } catch (Exception ex) { ex.printStackTrace() }
            })
            breadcrumbPanel.add(btn)
            bg.add(btn)
            if (i < displayPath.size() - 1) {
                JLabel arrow = new JLabel(" ← ")
                arrow.setFont(arrow.getFont().deriveFont(Font.BOLD))
                breadcrumbPanel.add(arrow)
            }
        }
        if (breadcrumbPanel.getComponentCount() > 0) {
            for (Component comp : breadcrumbPanel.getComponents()) {
                if (comp instanceof JRadioButton) ((JRadioButton) comp).setSelected(false)
            }
            Component last = breadcrumbPanel.getComponent(breadcrumbPanel.getComponentCount() - 1)
            if (last instanceof JRadioButton) ((JRadioButton) last).setSelected(true)
            else if (breadcrumbPanel.getComponentCount() > 1) {
                Component secondLast = breadcrumbPanel.getComponent(breadcrumbPanel.getComponentCount() - 2)
                if (secondLast instanceof JRadioButton) ((JRadioButton) secondLast).setSelected(true)
            }
        }
        breadcrumbPanel.revalidate()
        breadcrumbPanel.repaint()
    }
    
    private void doSearch() {
        String keyword = searchField.text.trim()
        if (keyword.isEmpty()) return
        
        boolean searchCore = coreCheck.selected
        boolean searchDetails = detailsCheck.selected
        boolean searchNote = noteCheck.selected
        if (!searchCore && !searchDetails && !searchNote) {
            JOptionPane.showMessageDialog(frame, "حداقل یک گزینه جستجو انتخاب کنید")
            return
        }
        
        def styleNames = []
        if (styleScopeRadio.selected) {
            String raw = styleField.text.trim()
            if (raw.isEmpty()) {
                JOptionPane.showMessageDialog(frame, "نام سبک را وارد کنید")
                return
            }
            styleNames = raw.split(/[;,\\.]+/).collect{ it.trim() }.findAll{ !it.isEmpty() }
            if (styleNames.isEmpty()) {
                JOptionPane.showMessageDialog(frame, "نام سبک معتبر وارد کنید (با ویرگول، نقطه ویرگول یا نقطه جدا کنید)")
                return
            }
        }
        
        tableModel.setRowCount(0)
        clearPreview()
        
        def maps = []
        if (folderRadio.selected) {
            File dir = new File(baseDir)
            if (!dir.exists() || !dir.isDirectory()) {
                JOptionPane.showMessageDialog(frame, "پوشه نامعتبر: $baseDir")
                return
            }
            def files = dir.listFiles().findAll { it.name.endsWith(".mm") }
            if (files.isEmpty()) {
                JOptionPane.showMessageDialog(frame, "هیچ فایل .mm در پوشه یافت نشد")
                return
            }
            files.each { file ->
                try {
                    def map = ScriptUtils.c().mapLoader(file).mindMap
                    maps << map
                } catch (Exception e) {
                    println "خطا در بارگذاری $file.name: $e.message"
                }
            }
        } else {
            maps = ScriptUtils.c().openMindMaps
            if (maps.isEmpty()) {
                JOptionPane.showMessageDialog(frame, "هیچ نقشه‌ای باز نیست")
                return
            }
        }
        
        if (maps.isEmpty()) {
            JOptionPane.showMessageDialog(frame, "هیچ نقشه‌ای برای جستجو یافت نشد")
            return
        }
        
        for (def map : maps) {
            try {
                map.root.findAll().each { node ->
                    if (isMatch(node, keyword, styleNames, searchCore, searchDetails, searchNote)) {
                        String fileName = map.file?.name ?: "بدون نام"
                        String styleName = node.style?.name ?: "(بدون سبک)"
                        tableModel.addRow([ fileName, styleName, [node] as Object[] ] as Object[])
                        String pathKey = map.file?.absolutePath ?: "unsaved"
                        if (!PATH_COLORS.containsKey(pathKey)) {
                            PATH_COLORS.put(pathKey, determineStringColor(pathKey))
                        }
                    }
                }
            } catch (Exception e) {
                println "خطا در نقشه ${map.file?.name}: $e.message"
            }
        }
        
        if (tableModel.rowCount == 0) {
            JOptionPane.showMessageDialog(frame, "نتیجه‌ای یافت نشد")
        } else {
            JOptionPane.showMessageDialog(frame, "${tableModel.rowCount} نتیجه یافت شد")
        }
    }
    
    private boolean isMatch(Node node, String keyword, def styleNames,
                            boolean searchCore, boolean searchDetails, boolean searchNote) {
        if (styleScopeRadio.selected && styleNames) {
            String nodeStyle = node.style?.name
            if (!nodeStyle || !styleNames.contains(nodeStyle)) return false
        }
        String kw = matchCase ? keyword : keyword.toLowerCase()
        if (searchCore) {
            String text = node.plainText ?: ""
            if (!matchCase) text = text.toLowerCase()
            if (wholeWord ? text ==~ /.*\b$kw\b.*/ : text.contains(kw)) return true
        }
        if (searchDetails && node.details?.plain) {
            String text = node.details.plain
            if (!matchCase) text = text.toLowerCase()
            if (wholeWord ? text ==~ /.*\b$kw\b.*/ : text.contains(kw)) return true
        }
        if (searchNote && node.note?.plain) {
            String text = node.note.plain
            if (!matchCase) text = text.toLowerCase()
            if (wholeWord ? text ==~ /.*\b$kw\b.*/ : text.contains(kw)) return true
        }
        return false
    }
    
    private void goToNode(int row) {
        int modelRow = resultsTable.convertRowIndexToModel(row)
        Object value = tableModel.getValueAt(modelRow, 2)
        Node node = null
        if (value instanceof Object[] && ((Object[]) value).length > 0) {
            node = ((Object[]) value)[0] as Node
        } else if (value instanceof Node) {
            node = value as Node
        }
        if (node != null) {
            try {
                ScriptUtils.c().select(node)
                def mapFile = node.mindMap.file
                if (mapFile) {
                    def uri = mapFile.toURI().toString() + "#" + node.id
                    def link = new org.freeplane.core.util.Hyperlink(new URI(uri))
                    org.freeplane.features.url.UrlManager.getController().loadHyperlink(link)
                }
            } catch (Exception e) {
                e.printStackTrace()
                JOptionPane.showMessageDialog(frame, "خطا در رفتن به گره: ${e.message}")
            }
        }
    }
    
    private void focusSearchField() {
        SwingUtilities.invokeLater({
            if (searchField != null) {
                searchField.requestFocusInWindow()
                searchField.selectAll()
            }
        })
    }
    
    class NodeCellWrapRenderer extends JTextArea implements TableCellRenderer {
        NodeCellWrapRenderer() {
            setLineWrap(true)
            setWrapStyleWord(true)
            setMargin(new Insets(5, 5, 5, 5))
            setOpaque(true)
            setBorder(BorderFactory.createEmptyBorder(2, 2, 2, 2))
        }
        
        @Override
        public Component getTableCellRendererComponent(JTable table, Object value, boolean isSelected, boolean hasFocus, int row, int column) {
            Node node = null
            if (value instanceof Object[] && ((Object[]) value).length > 0) {
                node = ((Object[]) value)[0] as Node
            } else if (value instanceof Node) {
                node = value as Node
            }
            String displayText = node != null ? (node.plainText ?: "") : ""
            String shortText = TextUtils.getShortText(displayText, 80, "\u2026")
            setText(shortText)
            setToolTipText(displayText)
            
            Color borderColor = Color.GRAY
            if (node != null && node.mindMap?.file != null) {
                String path = node.mindMap.file.absolutePath
                if (PATH_COLORS.containsKey(path)) {
                    borderColor = PATH_COLORS.get(path)
                }
            }
            // فقط حاشیه عمودی سمت راست (برای نشان دادن فایل) - بدون خط افقی
            Border border = BorderFactory.createMatteBorder(0, 5, 0, 0, borderColor)
            setBorder(BorderFactory.createCompoundBorder(border, BorderFactory.createEmptyBorder(0, 10, 0, 10)))
            
            setBackground(isSelected ? table.getSelectionBackground() : table.getBackground())
            setForeground(isSelected ? table.getSelectionForeground() : table.getForeground())
            setFont(table.getFont())
            
            // تنظیم ارتفاع سطر بر اساس محتوا (برای نمایش کامل متن)
            setSize(table.getColumnModel().getColumn(column).getWidth(), Short.MAX_VALUE)
            int preferredHeight = getPreferredSize().height + 10
            if (table.getRowHeight(row) != preferredHeight) {
                table.setRowHeight(row, preferredHeight)
            }
            return this
        }
    }
    
